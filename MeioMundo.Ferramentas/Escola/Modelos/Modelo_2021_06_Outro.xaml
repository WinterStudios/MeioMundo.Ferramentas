<UserControl x:Class="MeioMundo.Ferramentas.Escola.Modelos.Modelo_2021_06_Outro"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MeioMundo.Ferramentas.Escola.Modelos"
             xmlns:internal="clr-namespace:MeioMundo.Ferramentas.Escola.Internal"
             xmlns:xaml="clr-namespace:MeioMundo.Ferramentas.Escola.XAML"
             mc:Ignorable="d"
             Width="21cm" Height="29.7cm"
             Padding="0.5cm">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MeioMundo.Ferramentas;component/Escola/Modelos/ResourceDictionary_Modelo_MAIN.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="Color.Background.Light" Color="#FFB2CDD1"/>
            <SolidColorBrush x:Key="Color.Border.Light" Color="#FF4CB0CB"/>
            <SolidColorBrush x:Key="Color.Background.Main" Color="#FF60C2D1"/>
            <VisualBrush x:Key="Color.Brush.Pattern.Right" TileMode="Tile" Viewport="0,0,5,5" Viewbox="0,0,10,10" ViewboxUnits="Absolute" ViewportUnits="Absolute">
                <VisualBrush.Visual>
                    <Grid Background="Black">
                        <Path Data="M 9.5 0 L 10 0 L 10 0.5 L 0.5 10 L 0 10 L 0 9.5 Z M 0 0.5 L 0.5 0 L 0 0 Z M 4.5 0 L 5.5 0 L 0 5.5 L 0 4.5 Z M 4.5 10 L 10 4.5 L 10 5.5 L 5.4 10 Z M 9.5 10 L 10 9.5 L 10 10 Z" Fill="Black"/>
                    </Grid>
                </VisualBrush.Visual>
            </VisualBrush>
            <VisualBrush x:Key="Brush.Triangle.End" TileMode="Tile" Viewport="0,0,10,10" Viewbox="0,0,10,10" ViewboxUnits="RelativeToBoundingBox" ViewportUnits="RelativeToBoundingBox">
                <VisualBrush.Visual>
                    <Grid>
                        <Path Data="M 0 0 L 10 10 L 0 10 Z" Fill="{DynamicResource Color.Background.Light}"/>
                    </Grid>
                </VisualBrush.Visual>
            </VisualBrush>
            <internal:LongToStringConvert x:Key="LongToStringConvert"/>
            <internal:IntToStringConvert x:Key="IntToStringConvert"/>
            <xaml:GetBookByIDExtension x:Key="GetBookByIDExtension"/>

            <Style x:Key="DataGrid_Componetes" TargetType="DataGrid">
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="CanUserResizeColumns" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="Focusable" Value="True"/>
                <Setter Property="IsEnabled" Value="False"/>
                <Setter Property="HeadersVisibility" Value="None"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="FontSize" Value="8pt"/>
                <Setter Property="FontFamily" Value="Calibri Light"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderThickness" Value="0.25pt"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Color.Border.Light}"/>
                <Setter Property="AlternationCount" Value="2"/>
                <Setter Property="CellStyle" Value="{DynamicResource DataGrid_Cell}"/>
                <Setter Property="RowStyle" Value="{DynamicResource DataGeid_Row}"/>
            </Style>

            <Style x:Key="DataGeid_Row" TargetType="DataGridRow">
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="{DynamicResource Color.Background.Light}"/>
                <Style.Triggers>
                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                        <Setter Property="Background" Value="White" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DataGrid_Cell" TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0.25pt"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Color.Border.Light}"/>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="Black"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <SolidColorBrush x:Key="MODELO.2026.BRUSH.Border.Light" Color="#3b7680"/>

            <Style x:Key="DataGrid_Componetes_SELECTION" TargetType="DataGrid">
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="CanUserResizeColumns" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="Focusable" Value="True"/>
                <Setter Property="IsEnabled" Value="False"/>
                <Setter Property="HeadersVisibility" Value="None"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="FontSize" Value="8pt"/>
                <Setter Property="FontFamily" Value="Calibri Light"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderThickness" Value="0.25pt"/>
                <Setter Property="BorderBrush" Value="{DynamicResource MODELO.2021.BRUSH.Border.Light}"/>
                <Setter Property="AlternationCount" Value="2"/>
                <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
                <Setter Property="CellStyle" Value="{DynamicResource DataGrid_Cell_SELECTION}"/>
                <Setter Property="RowStyle" Value="{DynamicResource DataGeid_Row_SELECTION}"/>
            </Style>

            <Style x:Key="DataGeid_Row_SELECTION" TargetType="DataGridRow">
                <Setter Property="Margin" Value="0"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Height" Value="1cm" />
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="9pt" />
                <Setter Property="FontFamily" Value="Calibri" />
                <Setter Property="BorderThickness" Value="0.25pt"/>
                <Setter Property="BorderBrush" Value="{DynamicResource MODELO.2021.BRUSH.Border.Light}"/>
                <Setter Property="Background" Value="{DynamicResource MODELO.2021.BRUSH.BACKGROUND.DISC.OP}"/>
                <Style.Triggers>
                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                        <Setter Property="Background" Value="{DynamicResource MODELO.2021.BRUSH.BACKGROUND.DISC.OP}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DataGrid_Cell_SELECTION" TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0.25pt"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Padding" Value=".1cm,0"/>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="Black"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="Black"/>
            </Style>
            <Style x:Key="TextHeaderes" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="FontFamily" Value="Calibri"/>
                <Setter Property="FontSize" Value="9pt"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="Border.Line" TargetType="{x:Type Border}">
                <Setter Property="BorderThickness" Value=".5pt,0,.5pt,.5pt"/>
                <Setter Property="Height" Value="0.2cm"/>
                <Setter Property="VerticalAlignment" Value="Bottom"/>
                <Setter Property="Margin" Value=".25cm,0,0,0"/>
                <Setter Property="BorderBrush" Value="{DynamicResource MODELO.2021.BRUSH.Main}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="1cm" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!-- ============================= Row 0 : Cabeçalho (ambas as colunas) ============================= -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" BorderBrush="#000" Height="0.8cm" HorizontalAlignment="Stretch" RenderOptions.EdgeMode="Aliased">
            <Grid Background="{DynamicResource Color.Background.Light}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <DockPanel Margin=".25cm,0" VerticalAlignment="Center" LastChildFill="True">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="UC_TextBox_Ano" FontSize="14pt" FontFamily="Segui" VerticalAlignment="Center" Text="EPTOLIVA" Foreground="Black" />
                    </StackPanel>
                </DockPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin=".25cm,0" Orientation="Horizontal" Visibility="Visible">
                    <TextBlock Text="Ano Letivo " Foreground="Black" FontSize="14pt" VerticalAlignment="Center" FontWeight="Normal"/>
                    <TextBlock Text="2026/2027" Foreground="Black" FontSize="14pt" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================= Row 1 : Componente Geral (ambas as colunas) ============================= -->
        <Grid Grid.Row="1" Grid.ColumnSpan="3">
            <StackPanel Orientation="Vertical">
                <Border Height="0.4cm" Background="{DynamicResource Color.Background.Main}">
                    <TextBlock Text="Componente Geral" Foreground="Black" HorizontalAlignment="Center" FontFamily="Segui" FontWeight="Normal" VerticalAlignment="Center"/>
                </Border>
                <DataGrid x:Name="UC_DISC_COMP_GERAL" Style="{DynamicResource DataGrid_Componetes}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Disciplina" Binding="{Binding FullNome}" Width="3cm"/>
                        <DataGridTextColumn Header="ISBN" Binding="{Binding Livro_ID, Converter={StaticResource GetBookByIDExtension}, ConverterParameter=Livro_ISBN}" Width="2.5cm"/>
                        <DataGridTextColumn Header="Nome do Livro" Binding="{Binding Livro_ID, Converter={StaticResource GetBookByIDExtension}, ConverterParameter=Livro_Nome}" Width="8.48cm" />
                        <DataGridTextColumn Header="Autor do Livro" Binding="{Binding Livro_ID, Converter={StaticResource GetBookByIDExtension}, ConverterParameter=Livro_Autor}" Width="3cm"/>
                        <DataGridTextColumn Header="Editora do Livro" Binding="{Binding Livro_ID, Converter={StaticResource GetBookByIDExtension}, ConverterParameter=Livro_Editora}" Width="3cm"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>

        <!-- ============================= Row 2 / Coluna 0 : 1ª via (esquerda) ============================= -->
        <Grid Grid.Row="2" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- CURSO -->
            <StackPanel Grid.Row="0">
                <Border Margin="0,0.5cm">
                    <StackPanel>
                        <DockPanel Height="0.75cm" Margin="0,0.25cm">
                            <Border Width="2cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                <TextBlock Text="CURSO" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="12pt" Style="{DynamicResource TextHeaderes}"/>
                            </Border>
                            <Border Width="7cm" HorizontalAlignment="Left" Style="{DynamicResource Border.Line}" />
                        </DockPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Nome / Morada / Fatura / NIF + Disciplinas -->
            <Grid Grid.Row="1">
                <StackPanel>
                    <Border>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Grid.ColumnSpan="2">
                                <StackPanel Orientation="Vertical">
                                    <DockPanel Height="0.75cm">
                                        <Border Width="2cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                            <TextBlock Text="Nome" Style="{DynamicResource TextHeaderes}"/>
                                        </Border>
                                        <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}" />
                                    </DockPanel>
                                    <DockPanel Margin="0cm,.25cm,0,0">
                                        <Border Width="2cm" Height="0.75cm" VerticalAlignment="Top" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                            <TextBlock Text="Morada" Style="{DynamicResource TextHeaderes}" />
                                        </Border>
                                        <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}" />
                                    </DockPanel>
                                </StackPanel>
                            </DockPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <StackPanel Width="3.25cm" Margin="0,0.5cm,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Border Style="{DynamicResource MODELO.2021.BORDER.FILL}" Height="0.5cm">
                                        <TextBlock Text="Fatura" Style="{DynamicResource TextHeaderes}"/>
                                    </Border>
                                    <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}" Height="1cm"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="1" Grid.Row="2" Margin=".5cm,.25cm,0,0">
                                <StackPanel>
                                    <Border Margin="0,.25cm,0,0">
                                        <DockPanel Height="0.75cm">
                                            <Border Width="1cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                                <TextBlock Text="NIF" Style="{DynamicResource TextHeaderes}" />
                                            </Border>
                                            <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}" />
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <Grid Margin="0,.5cm,0,0">
                        <Grid VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2cm"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                <TextBlock Text="Disciplina" Style="{DynamicResource TextHeaderes}"/>
                            </Border>
                            <Border Grid.Column="1" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                <TextBlock Text="Manual" Style="{DynamicResource TextHeaderes}"/>
                            </Border>
                            <DataGrid Grid.Row="1" x:Name="UC_ItemControl_Disciplinas" Grid.ColumnSpan="2" ItemsSource="{Binding Disciplinas}" Style="{DynamicResource DataGrid_Componetes_SELECTION}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Disciplina" Binding="{Binding FullNome}" Width="*"/>
                                    <DataGridTextColumn Header="ISBN" Width="2cm">
                                        <DataGridTextColumn.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Background" Value="White"/>
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Row="2" Height="0.2cm" Fill="{DynamicResource Color.Border.Light}" Margin="0,0.5cm" />

            <!-- Encapar / Representante -->
            <StackPanel Grid.Row="3">
                <Border Height="0.75cm">
                    <DockPanel>
                        <Border Width="2.5cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                            <TextBlock Text="Encapar" Style="{DynamicResource TextHeaderes}"/>
                        </Border>
                        <Border Width="1cm" Style="{DynamicResource MODELO.2021.BORDER.LINES}">
                            <TextBlock Text="Sim" Style="{DynamicResource TextHeaderes}"/>
                        </Border>
                        <Border Width="1cm" Style="{DynamicResource MODELO.2021.BORDER.LINES}">
                            <TextBlock Text="Não" Style="{DynamicResource TextHeaderes}"/>
                        </Border>
                        <Border Width="1.5cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                            <TextBlock Text="Data" Style="{DynamicResource TextHeaderes}"/>
                        </Border>
                        <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}"/>
                    </DockPanel>
                </Border>
                <Border>
                    <DockPanel Height="0.75cm">
                        <Border Width="2.5cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                            <TextBlock Text="Representante" Style="{DynamicResource TextHeaderes}"/>
                        </Border>
                        <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}"/>
                    </DockPanel>
                </Border>
            </StackPanel>

            <!-- Notas -->
            <Border Grid.Row="4" Margin="0,.5cm,0,0" Style="{DynamicResource MODELO.2021.BORDER.LINES}">
                <Border Width="2cm" Height="0.5cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}" VerticalAlignment="Top" HorizontalAlignment="Left">
                    <TextBlock Text="Notas" Style="{DynamicResource TextHeaderes}"/>
                </Border>
            </Border>
        </Grid>

        <!-- ============================= Row 2 / Coluna 1 : Separador vertical ============================= -->
        <Grid Grid.Row="2" Grid.Column="1">
            <Rectangle Width="4pt" HorizontalAlignment="Center" Fill="Black" Margin="0,0.75cm" />
        </Grid>

        <!-- ============================= Row 2 / Coluna 2 : 2ª via (direita — espelho) ============================= -->
        <Grid Grid.Row="2" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- CURSO -->
            <StackPanel Grid.Row="0">
                <Border Margin="0,0.5cm">
                    <StackPanel>
                        <DockPanel Height="0.75cm" Margin="0,0.25cm">
                            <Border Width="2cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                <TextBlock Text="CURSO" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="12pt" Style="{DynamicResource TextHeaderes}"/>
                            </Border>
                            <Border Width="7cm" HorizontalAlignment="Left" Style="{DynamicResource Border.Line}" />
                        </DockPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Nome / Morada / Fatura / NIF + Disciplinas -->
            <Grid Grid.Row="1">
                <StackPanel>
                    <Border>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Grid.ColumnSpan="2">
                                <StackPanel Orientation="Vertical">
                                    <DockPanel Height="0.75cm">
                                        <Border Width="2cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                            <TextBlock Text="Nome" Style="{DynamicResource TextHeaderes}"/>
                                        </Border>
                                        <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}" />
                                    </DockPanel>
                                    <DockPanel Margin="0cm,.25cm,0,0">
                                        <Border Width="2cm" Height="0.75cm" VerticalAlignment="Top" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                            <TextBlock Text="Morada" Style="{DynamicResource TextHeaderes}" />
                                        </Border>
                                        <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}" />
                                    </DockPanel>
                                </StackPanel>
                            </DockPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <StackPanel Width="3.25cm" Margin="0,0.5cm,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Border Style="{DynamicResource MODELO.2021.BORDER.FILL}" Height="0.5cm">
                                        <TextBlock Text="Fatura" Style="{DynamicResource TextHeaderes}"/>
                                    </Border>
                                    <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}" Height="1cm"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="1" Grid.Row="2" Margin=".5cm,.25cm,0,0">
                                <StackPanel>
                                    <Border Margin="0,.25cm,0,0">
                                        <DockPanel Height="0.75cm">
                                            <Border Width="1cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                                <TextBlock Text="NIF" Style="{DynamicResource TextHeaderes}" />
                                            </Border>
                                            <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}" />
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <Grid Margin="0,.5cm,0,0">
                        <Grid VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2cm"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                <TextBlock Text="Disciplina" Style="{DynamicResource TextHeaderes}"/>
                            </Border>
                            <Border Grid.Column="1" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                                <TextBlock Text="Manual" Style="{DynamicResource TextHeaderes}"/>
                            </Border>
                            <DataGrid Grid.Row="1" x:Name="UC_ItemControl_Disciplinas_Copy" Grid.ColumnSpan="2" ItemsSource="{Binding Disciplinas}" Style="{DynamicResource DataGrid_Componetes_SELECTION}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Disciplina" Binding="{Binding FullNome}" Width="*"/>
                                    <DataGridTextColumn Header="ISBN" Width="2cm">
                                        <DataGridTextColumn.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Background" Value="White"/>
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Row="2" Height="0.2cm" Fill="{DynamicResource Color.Border.Light}" Margin="0,0.5cm" />

            <!-- Encapar / Representante -->
            <StackPanel Grid.Row="3">
                <Border Height="0.75cm">
                    <DockPanel>
                        <Border Width="2.5cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                            <TextBlock Text="Encapar" Style="{DynamicResource TextHeaderes}"/>
                        </Border>
                        <Border Width="1cm" Style="{DynamicResource MODELO.2021.BORDER.LINES}">
                            <TextBlock Text="Sim" Style="{DynamicResource TextHeaderes}"/>
                        </Border>
                        <Border Width="1cm" Style="{DynamicResource MODELO.2021.BORDER.LINES}">
                            <TextBlock Text="Não" Style="{DynamicResource TextHeaderes}"/>
                        </Border>
                        <Border Width="1.5cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                            <TextBlock Text="Data" Style="{DynamicResource TextHeaderes}"/>
                        </Border>
                        <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}"/>
                    </DockPanel>
                </Border>
                <Border>
                    <DockPanel Height="0.75cm">
                        <Border Width="2.5cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}">
                            <TextBlock Text="Representante" Style="{DynamicResource TextHeaderes}"/>
                        </Border>
                        <Border Style="{DynamicResource MODELO.2021.BORDER.LINES}"/>
                    </DockPanel>
                </Border>
            </StackPanel>

            <!-- Notas -->
            <Border Grid.Row="4" Margin="0,.5cm,0,0" Style="{DynamicResource MODELO.2021.BORDER.LINES}">
                <Border Width="2cm" Height="0.5cm" Style="{DynamicResource MODELO.2021.BORDER.FILL}" VerticalAlignment="Top" HorizontalAlignment="Left">
                    <TextBlock Text="Notas" Style="{DynamicResource TextHeaderes}"/>
                </Border>
            </Border>
        </Grid>

    </Grid>
</UserControl>
